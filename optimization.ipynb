import pulp
import numpy as np
import matplotlib.pyplot as plt

# Create Model
model = pulp.LpProblem("Profit_Maximization", pulp.LpMaximize)

# Variables
x = pulp.LpVariable('Product_A', lowBound=0)
y = pulp.LpVariable('Product_B', lowBound=0)

# Objective Function
model += 40 * x + 30 * y

# Constraints
model += 2 * x + y <= 100
model += x + y <= 80
model += y <= 40

# Solve
model.solve()

# Output
print("Status:", pulp.LpStatus[model.status])
print("Product A =", x.varValue)
print("Product B =", y.varValue)
print("Max Profit = ₹", pulp.value(model.objective))

# Graph
x_vals = np.linspace(0, 100, 100)
y1 = 100 - 2*x_vals
y2 = 80 - x_vals
y3 = 40

plt.plot(x_vals, y1, label="2x + y = 100")
plt.plot(x_vals, y2, label="x + y = 80")
plt.axhline(y=40, linestyle='--', label="y = 40")

plt.fill_between(x_vals, 0, np.minimum(np.minimum(y1, y2), y3), alpha=0.3)

plt.scatter(x.varValue, y.varValue, label='Optimal Point')

plt.xlabel("Product A")
plt.ylabel("Product B")
plt.legend()
plt.grid()

plt.show()
